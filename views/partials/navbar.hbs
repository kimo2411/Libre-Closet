<div class="navbar bg-base-100 border-b border-base-300 sticky top-0 z-40">
  <div class="flex-1">
    <a class="btn btn-ghost text-lg px-2" href="/locations">
      <span class="inline-flex size-8 items-center justify-center rounded bg-base-200 text-base font-bold">衣</span>
      <span>{{appName}}</span>
    </a>
  </div>
  <div class="flex-none">
    <a class="btn btn-ghost btn-sm" href="/locations">衣物位置</a>
    {{#if authEnabled}}
      {{#if user}}
        <a class="btn btn-ghost btn-sm" href="/auth/logout">退出</a>
      {{else}}
        {{#unless signupsDisabled}}
          <a class="btn btn-ghost btn-sm" href="/auth/register">注册</a>
        {{/unless}}
        <a class="btn btn-ghost btn-sm" href="/auth/login">登录</a>
      {{/if}}
    {{/if}}
  </div>
</div>
