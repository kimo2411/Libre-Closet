{{>navbar}}

<main class="p-4 pt-20 pb-24 max-w-lg mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a
      href="{{#if garment}}/wardrobe/{{garment.id}}{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{else}}/wardrobe{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{/if}}"
      class="btn btn-ghost btn-sm btn-circle"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="size-4"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
        />
      </svg>
    </a>
    <h1 class="text-2xl font-bold">
      {{#if isClone}}{{t 'lang.CLONE_GARMENT'}}{{else if garment}}{{t 'lang.EDIT_GARMENT'}}{{else}}{{t 'lang.NEW_GARMENT'}}{{/if}}
    </h1>
  </div>

  <form
    method="POST"
    action="{{#if isClone}}/wardrobe/{{garment.id}}/clone{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{else if garment}}/wardrobe/{{garment.id}}{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{else}}/wardrobe{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{/if}}"
    class="flex flex-col gap-4"
  >
    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.NAME'}}</span></label
      >
      <input
        type="text"
        name="name"
        class="input input-bordered"
        value="{{#if isClone}}{{cloneName}}{{else if garment}}{{garment.name}}{{/if}}"
        placeholder="e.g. Black Linen Blazer"
      />
    </div>

    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.CATEGORY'}} *</span></label
      >
      <input
        type="text"
        name="category"
        list="category-suggestions"
        class="input input-bordered w-full"
        value="{{#if garment}}{{garment.category}}{{/if}}"
        required
        placeholder="{{t 'lang.TYPE_OR_SELECT_CATEGORY'}}"
        autocomplete="off"
      />
      <datalist id="category-suggestions">
        {{#each categories}}
        <option value="{{this.value}}"></option>
        {{/each}}
      </datalist>
    </div>

    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.BRAND'}}</span></label
      >
      <input
        type="text"
        name="brand"
        class="input input-bordered"
        value="{{#if garment}}{{garment.brand}}{{/if}}"
        placeholder="e.g. Levi's"
      />
    </div>

    {{> colorMultiSelect colors=colors garment=garment}}

    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.SIZE'}}</span></label
      >
      <input
        type="text"
        name="size"
        class="input input-bordered"
        value="{{#if garment}}{{garment.size}}{{/if}}"
        placeholder="M, 32, One Size…"
      />
    </div>

    <div class="form-control">
      <label class="label"><span class="label-text">{{t 'lang.WASHING_DETAILS'}}</span></label>
      <textarea
        name="washingDetails"
        class="textarea textarea-bordered"
        rows="3"
        placeholder="Wash at 30°C, do not tumble dry, do not iron…"
      >{{#if garment}}{{garment.washingDetails}}{{/if}}</textarea>
    </div>

    <div class="form-control">
      <label class="label"><span class="label-text">{{t 'lang.DATE_AQUIRED'}}</span></label>
      <input
        type="date"
        name="dateAquired"
        class="input input-bordered"
        value="{{formatDate garment.dateAquired}}"
      />
    </div>

    <div class="form-control">
      <label class="label"><span class="label-text">{{t 'lang.NOTES'}}</span></label>
      <textarea
        name="notes"
        class="textarea textarea-bordered"
        rows="3"
        placeholder="Any notes about this garment…"
      >
{{#if garment}}{{garment.notes}}{{/if}}</textarea
      >
    </div>

    <div class="flex gap-2 mt-2">
      <a
        href="{{#if garment}}/wardrobe/{{garment.id}}{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{else}}/wardrobe{{#if viewOwner}}?ownerId={{viewOwner}}{{/if}}{{/if}}"
        class="btn btn-ghost flex-1"
        >{{t 'lang.CANCEL'}}</a
      >
      <button type="submit" class="btn btn-primary flex-1">
        {{t 'lang.SAVE'}}
      </button>
    </div>
  </form>
</main>

{{>dock}}
