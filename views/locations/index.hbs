{{>navbar}}

<main class="min-h-screen bg-base-100 pb-28">
  <section class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-4 py-6 md:px-8">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-2xl font-bold md:text-3xl">衣物存储位置</h1>
        <p class="mt-1 text-sm text-base-content/60">先建立衣柜、抽屉、收纳箱等位置，再进去批量上传衣物照片。</p>
      </div>
      <button class="btn btn-primary" onclick="new_location.showModal()">新增位置</button>
    </div>

    {{#if locations.length}}
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {{#each locations}}
          <a href="/locations/{{location.id}}" class="card bg-base-200 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <figure class="aspect-[4/3] bg-base-300">
              {{#if location.cover}}
                <img src="/file/{{location.cover.fileName}}" alt="{{location.name}}" class="h-full w-full object-cover" loading="lazy" />
              {{else}}
                <div class="flex h-full w-full items-center justify-center text-base-content/40">
                  <span class="text-5xl">+</span>
                </div>
              {{/if}}
            </figure>
            <div class="card-body gap-2 p-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="card-title text-lg">{{location.name}}</h2>
                <span class="badge badge-neutral">{{itemCount}} 张</span>
              </div>
              {{#if location.notes}}
                <p class="line-clamp-2 text-sm text-base-content/60">{{location.notes}}</p>
              {{/if}}
            </div>
          </a>
        {{/each}}
      </div>
    {{else}}
      <div class="flex min-h-[50vh] flex-col items-center justify-center rounded bg-base-200 px-6 text-center">
        <div class="text-5xl font-light text-base-content/30">+</div>
        <h2 class="mt-4 text-xl font-semibold">还没有存储位置</h2>
        <p class="mt-2 max-w-md text-sm text-base-content/60">例如“主卧衣柜上层”“玄关收纳箱”“儿童房抽屉”。建好位置后，就能按位置查看衣物照片。</p>
        <button class="btn btn-primary mt-5" onclick="new_location.showModal()">新增第一个位置</button>
      </div>
    {{/if}}
  </section>
</main>

<dialog id="new_location" class="modal">
  <div class="modal-box max-w-md">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">x</button>
    </form>
    <h2 class="text-xl font-bold">新增存储位置</h2>
    <form class="mt-5 flex flex-col gap-4" method="post" action="/locations" enctype="multipart/form-data">
      <label class="form-control">
        <span class="label-text mb-1">位置名称</span>
        <input class="input input-bordered" name="name" placeholder="例如：主卧衣柜左侧" required />
      </label>
      <label class="form-control">
        <span class="label-text mb-1">备注</span>
        <textarea class="textarea textarea-bordered min-h-20" name="notes" placeholder="可选"></textarea>
      </label>
      <label class="form-control">
        <span class="label-text mb-1">位置照片</span>
        <input class="file-input file-input-bordered" name="cover" type="file" accept="image/*" />
      </label>
      <button class="btn btn-primary" type="submit">保存位置</button>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

{{>dock}}
