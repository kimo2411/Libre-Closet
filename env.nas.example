APP_NAME=家庭衣物相册
PORT=3000
DATA_PATH=/app/data

# Personal NAS defaults.
AUTH_ENABLED=false
DISABLE_REGISTRATION=true
PWA_ENABLED=false

# Change this before exposing the app outside your home network.
ACCESS_TOKEN_SECRET=ChangeThisToALongRandomSecret

# SQLite and local files are the simplest setup for Synology, QNAP, Unraid,
# TrueNAS, CasaOS, Portainer, and similar personal NAS environments.
DATABASE_TYPE=sqlite
FILE_STORAGE_TYPE=local

# Optional: set this to your LAN or reverse-proxy URL, for example:
# SITE_URL=http://192.168.1.20:3000
# SITE_URL=https://closet.example.com
