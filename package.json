{
  "name": "libre-closet",
  "version": "0.5.0",
  "description": "A free, open-source digital wardrobe organizer. Catalog your clothing, build outfits, and share looks.",
  "author": "Lazztech LLC",
  "private": true,
  "license": "AGPL-3.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "nest build && npm run generate",
    "generate": "npm run generate:tailwind",
    "generate:tailwind": "tailwindcss -i ./views/assets/main.css -o ./public/bundle.css --minify",
    "generate:tailwind:watch": "tailwindcss -i ./views/assets/main.css -o ./public/bundle.css --minify --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run generate && nest start",
    "start:dev": "concurrently \"nest start --watch\" \"npm run generate:tailwind:watch\"",
    "start:debug": "concurrently \"nest start --debug --watch\" \"npm run generate:tailwind:watch\"",
    "start:prod": "node dist/main",
    "lighthouse": "lhci autorun",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test test/smoke.spec.ts --project=chromium",
    "test:load": "ts-node scripts/load-test.ts",
    "test:load:baseline": "ts-node scripts/load-test.ts --baseline",
    "test:load:compare": "ts-node scripts/load-test.ts --compare",
    "precommit": "npm run format && npm run lint && npm run test:cov && npm run test:e2e:smoke && npm run build && npm run test:load && npm run lighthouse"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^11.0.0",
    "@mikro-orm/better-sqlite": "^6.5.8",
    "@mikro-orm/core": "^6.5.8",
    "@mikro-orm/migrations": "^6.5.8",
    "@mikro-orm/nestjs": "^6.1.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/throttler": "^6.4.0",
    "handlebars": "^4.7.8",
    "hbs": "^4.2.0",
    "joi": "^18.0.1",
    "nestjs-pino": "^4.4.1",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mikro-orm/cli": "^6.5.8",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.57.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/hbs": "^4.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@tailwindcss/cli": "^4.1.14",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "daisyui": "^5.1.27",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "npm-check-updates": "^19.1.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/migrations/**/*",
      "!**/entity/**/*",
      "!**/*.dto.*",
      "!**/*.input.*",
      "!**/*.module.*"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
